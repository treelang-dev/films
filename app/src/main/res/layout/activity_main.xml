<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#FAFAFA"
    android:fitsSystemWindows="true"
    android:padding="16dp">

    <!-- 标题栏 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">
        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="影院抓取 (终极优化版)"
            android:textColor="#333333"
            android:textSize="18sp"
            android:textStyle="bold" />

        <!-- 清除断点记录按钮 -->
        <Button
            android:id="@+id/btnClearCache"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:text="清除断点记录"
            android:textSize="10sp"
            android:backgroundTint="#FF9800"/>
    </LinearLayout>

    <!-- 输入框容器 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:background="@android:drawable/editbox_background"
        android:orientation="horizontal"
        android:padding="4dp">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Activity ID"
                android:textSize="10sp"
                android:textColor="#888888"/>
            <EditText
                android:id="@+id/activityIdEditText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@null"
                android:text="1714655"
                android:inputType="number"
                android:textSize="14sp"
                android:padding="4dp"/>
        </LinearLayout>

        <View
            android:layout_width="1dp"
            android:layout_height="match_parent"
            android:background="#DDDDDD"
            android:layout_margin="4dp"/>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="FCode"
                android:textSize="10sp"
                android:textColor="#888888"/>
            <EditText
                android:id="@+id/fcodeEditText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@null"
                android:text="2CRGVWAC799"
                android:textSize="14sp"
                android:padding="4dp"/>
        </LinearLayout>
    </LinearLayout>

    <!-- 线程调节滑块 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginTop="8dp">
        <TextView
            android:text="并发线程: "
            android:textSize="12sp"
            android:textColor="#333333"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>
        <TextView
            android:id="@+id/threadCountText"
            android:text="5"
            android:textStyle="bold"
            android:textColor="#2196F3"
            android:layout_width="24dp"
            android:gravity="center"
            android:layout_height="wrap_content"/>
        <SeekBar
            android:id="@+id/threadSeekBar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:max="10"
            android:min="1"
            android:progress="5"/>
    </LinearLayout>

    <Button
        android:id="@+id/startButton"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:layout_marginTop="8dp"
        android:text="开始任务"
        android:textStyle="bold"/>

    <!-- 进度信息 -->
    <ProgressBar
        android:id="@+id/progressBar"
        style="?android:attr/progressBarStyleHorizontal"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="4dp">
        <TextView
            android:id="@+id/progressText"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="就绪 0/0"
            android:textSize="12sp"
            android:textColor="#555555"/>
        <TextView
            android:id="@+id/tvWorkerStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="活跃: 0"
            android:textSize="12sp"
            android:textColor="#FF5722"/>
    </LinearLayout>

    <!-- 日志区域 -->
    <ScrollView
        android:id="@+id/logScrollView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginTop="8dp"
        android:background="#EEEEEE"
        android:padding="8dp">

        <TextView
            android:id="@+id/logTextView"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="系统就绪..."
            android:textSize="11sp"
            android:fontFamily="monospace"
            android:textColor="#222222" />
    </ScrollView>

    <!-- 隐藏的 WebView 容器 -->
    <LinearLayout
        android:id="@+id/webViewContainer"
        android:layout_width="1dp"
        android:layout_height="1dp"
        android:orientation="vertical"
        android:visibility="gone" />

</LinearLayout>